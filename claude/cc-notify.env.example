# Copy to ~/.claude/cc-notify.env (gitignored) and fill in.
# Create a bot via @BotFather; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
CC_NOTIFY_CHAT_ID=
# macOS desktop notification is OFF by default (iTerm2 shows its own alert, and
# osascript notifications misattribute to "Script Editor"). Set to 1 to enable.
CC_NOTIFY_MACOS=0
